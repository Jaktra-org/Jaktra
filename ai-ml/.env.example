

# LLM Configuration
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.1-8b-instant

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-specific-password
SMTP_SENDER_NAME=Finance Department

# Payment Details (included in follow-up emails)
PAYMENT_LINK=https://payments.example.com/portal
BANK_DETAILS=IBAN: GB00 0000 0000 0000 | SWIFT: EXAMPLEX

# Scheduling 
# SCHEDULE_HOUR: Time in HH:MM format for daily automated run
# TIMEZONE: IANA timezone string (e.g., Asia/Kolkata, UTC, US/Eastern)
SCHEDULE_HOUR=09:00
TIMEZONE=Asia/Kolkata

# Run Mode 
# true  → Generates emails and logs them locally (safe for testing)
# false → Sends real emails via SMTP
DRY_RUN=true
