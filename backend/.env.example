PORT=3001
NODE_ENV=development

# Required — PostgreSQL connection string
# Local:  postgresql://postgres:postgres@localhost:5432/jaktra
# Neon:   postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/jaktra

# Required — min 32 chars, use a strong random string in production
JWT_SECRET=change-me-to-a-strong-secret-at-least-32-chars-long
JWT_EXPIRES_IN=7d

# Required when C1 (FastAPI wrapper) is live
AI_ML_SERVICE_URL=http://localhost:8000
AI_ML_SERVICE_KEY=your_service_key_here

# Required when Redis is provisioned (rate limiting, session caching)
REDIS_URL=redis://localhost:6379

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# Optional — needed for A16 (email sending)
SENDGRID_API_KEY=SG.your_key_here

# Optional — needed for A19 (payment webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_secret
RAZORPAY_WEBHOOK_SECRET=your_secret

# Platform Email Sending
PLATFORM_SMTP_URL=smtps://user:password@smtp.gmail.com:465
PLATFORM_EMAIL_PROVIDER=smtp
PLATFORM_SENDGRID_API_KEY=SG.your_platform_key_here

